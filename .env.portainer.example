# Portainer / Docker Swarm environment template for stack.yml
# Configure GHCR credentials in Portainer Registry settings (not here).

# Image published to GHCR
WAKAPI_IMAGE_REPO=ghcr.io/salesadriano/wakapi
WAKAPI_IMAGE_TAG=latest

# Service port exposed by Swarm ingress
WAKAPI_PORT=3000

# Required secrets
WAKAPI_DB_PASSWORD=change_me_with_a_strong_password
WAKAPI_PASSWORD_SALT=change_me_with_a_long_random_salt

# Optional (keep empty if SMTP is disabled)
WAKAPI_MAIL_SMTP_PASS=
